    "build": "tsup src/index.ts --dts --format esm --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@interrobang/core": "workspace:*",
    "@interrobang/schema": "workspace:*",
    "ts-pattern": "5.9.0",
    "wa-sqlite": "1.0.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.12"
  }
}
