{
  "name": "@interrobang/font-io",
  "version": "0.0.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@interrobang/core": "workspace:*",
    "fast-xml-parser": "5.7.1",
    "opentype.js": "1.3.4"
  },
  "devDependencies": {
    "@types/bun": "1.3.12",
    "@types/opentype.js": "1.3.9"
  }
}
