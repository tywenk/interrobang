{
  "name": "interrobang",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun --filter '@interrobang/*' build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix --fix-suggestions",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "bun --filter '*' typecheck"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@vitejs/plugin-react": "6.0.1",
    "happy-dom": "20.9.0",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "tsup": "8.5.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  },
  "patchedDependencies": {
    "wa-sqlite@1.0.0": "patches/wa-sqlite@1.0.0.patch"
  }
}
